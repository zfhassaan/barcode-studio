{
  "name": "barcode-generator-extension",
  "version": "1.2.2",
  "scripts": {
    "build": "vite build",
    "build:all": "npm run build && node scripts/build-all-browsers.mjs",
    "dev": "vite",
    "icons": "node scripts/generate-icons.mjs",
    "generate:cws-key": "node scripts/cws-verified-upload.mjs generate",
    "pubkey:cws": "node scripts/cws-verified-upload.mjs pubkey",
    "pack:cws": "node scripts/cws-verified-upload.mjs pack",
    "release:cws": "npm run build && npm run pack:cws"
  },
  "keywords": [
    "chrome-extension",
    "barcode",
    "qr"
  ],
  "author": "zfhassaan",
  "license": "ISC",
  "description": "Chrome extension — QR and linear barcodes in the toolbar popup.",
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.33",
    "@vitejs/plugin-vue": "^6.0.5",
    "sharp": "^0.34.5",
    "vite": "^7.3.1",
    "vue": "^3.5.31"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "jsbarcode": "^3.12.3",
    "qrcode": "^1.5.4"
  }
}
